---
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import "../styles.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "AgentQ — Production-Ready Software, Launched in Days",
  description = "Agentic engineering with on-demand developer assistance. AI agents build your software. Human developers make sure it works. Production-ready code you own.",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet">
</head>
<body class="bg-sage-wash text-warm-black">
  <Nav />
  <main>
    <slot />
  </main>
  <Footer />
  <script>
    import "../scripts/main.js";
  </script>
</body>
</html>
