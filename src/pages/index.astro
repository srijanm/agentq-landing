---
import BaseLayout from "../layouts/BaseLayout.astro";

const calendarUrl = "https://calendar.google.com/calendar/u/0/appointments/schedules/AcZssZ2VXsiZVbhgdnhV1tkQ9J6N-roCQlSd4CDDA5BHEcf36xdz-4OJSNM_56LSe5vDu9G6-AZRXkCj";
---

<BaseLayout>

  <!-- ═══════════════════════════════════════════
       HERO SECTION — Centered, single column
       ═══════════════════════════════════════════ -->
  <section aria-label="Hero" class="hero-centered">
    <div class="hero-bg" aria-hidden="true">
      <img src="/images/hero-bg.png" alt="" class="hero-bg-img">
    </div>
    <div class="min-h-[100svh] flex flex-col items-center justify-start pt-28 md:pt-32 pb-8 relative z-10">
      <div class="max-w-[960px] mx-auto px-5 md:px-10 w-full text-center">

        <!-- Video pill -->
        <a href="#video" class="hero-video-pill mb-8 inline-flex">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><polygon points="5,3 12,7 5,11" fill="currentColor"/></svg>
          Watch a 90 second demo
        </a>

        <!-- Variant 1: Pain-based -->
        <div id="hero-v1" class="hero-variant">
          <h1 class="type-display text-warm-black mb-5">You built the demo. Now <span class="text-forest">launch</span> your&nbsp;product.</h1>
          <p class="type-h3 text-warm-mid mb-10 max-w-[672px] mx-auto">Production-ready apps in days. Clean code you own. A dev team when you need&nbsp;one.</p>
        </div>

        <!-- Variant 2: Outcome-based (default) -->
        <div id="hero-v2" class="hero-variant">
          <h1 class="type-display text-warm-black mb-5"><span class="text-forest">Bespoke software,</span> just for your business&nbsp;needs.</h1>
          <p class="type-h3 text-warm-mid mb-10 max-w-[672px] mx-auto">Custom apps ready to launch in days, not months. Supercharged AI written code. A dev team when you need&nbsp;one.</p>
        </div>

        <!-- Variant 3: Attacking VC -->
        <div id="hero-v3" class="hero-variant">
          <h1 class="type-display text-warm-black mb-5">What got you here won't get you&nbsp;<span class="text-forest">there.</span></h1>
          <p class="type-h3 text-warm-mid mb-10 max-w-[672px] mx-auto">Vibecoding got you 80% of the way. We'll ensure you cover the&nbsp;rest.</p>
        </div>

        <!-- Email CTA -->
        <form id="hero-form" class="hero-cta-row mb-6" novalidate>
          <input type="email" id="hero-email" class="hero-email-input" placeholder="Enter your email here" required>
          <a id="hero-cta-btn" href={calendarUrl} class="btn-primary hero-cta-btn" data-calendar-url={calendarUrl}>
            Book a Demo <span aria-hidden="true">&rarr;</span>
          </a>
        </form>
        <p id="hero-email-error" class="type-body-sm text-signal-red mb-4" style="display: none;">Please enter a valid email address.</p>

        <!-- Rotating social proof -->
        <div class="hero-social-proof" aria-live="polite">
          <div class="hero-proof-item active">
            <span class="text-warm-mid">&ldquo;Launched in 5 days. The developer support made the difference.&rdquo;</span>
            <span class="font-medium text-warm-black">&nbsp;&mdash; Founder, EdTech startup</span>
          </div>
          <div class="hero-proof-item">
            <span class="text-warm-mid">&ldquo;We spent three months on Lovable and couldn't ship. AgentQ got us live in a week.&rdquo;</span>
            <span class="font-medium text-warm-black">&nbsp;&mdash; CEO, SaaS company</span>
          </div>
          <div class="hero-proof-item">
            <span class="text-warm-mid">&ldquo;I'm not technical. AgentQ gave me production-ready software and a developer I could actually talk to.&rdquo;</span>
            <span class="font-medium text-warm-black">&nbsp;&mdash; Small business owner</span>
          </div>
        </div>
      </div>

      <!-- Animated 3→1 process diagram -->
      <div class="hero-process-diagram">
        <div class="hero-process-nodes">
          <div class="hero-node hero-node--step" style="--node-delay: 0.3s">
            Describe your product
          </div>
          <div class="hero-node hero-node--step" style="--node-delay: 0.6s">
            AI agents build it
          </div>
          <div class="hero-node hero-node--step" style="--node-delay: 0.9s">
            Real developers step in
          </div>
        </div>

        <!-- Connector lines (SVG) — tree structure with junction dots -->
        <svg class="hero-connectors" viewBox="0 0 800 120" fill="none" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
          <!-- Lines from step nodes down to junction points -->
          <line class="hero-connector-line" x1="133" y1="0" x2="133" y2="40"/>
          <line class="hero-connector-line" x1="400" y1="0" x2="400" y2="40"/>
          <line class="hero-connector-line" x1="667" y1="0" x2="667" y2="40"/>

          <!-- Lines from junctions converging to center -->
          <line class="hero-connector-line" x1="133" y1="40" x2="400" y2="90"/>
          <line class="hero-connector-line" x1="400" y1="40" x2="400" y2="90"/>
          <line class="hero-connector-line" x1="667" y1="40" x2="400" y2="90"/>

          <!-- Junction dots -->
          <circle class="hero-connector-dot" cx="133" cy="40" r="3.5"/>
          <circle class="hero-connector-dot" cx="400" cy="40" r="3.5"/>
          <circle class="hero-connector-dot" cx="667" cy="40" r="3.5"/>

          <!-- Center convergence dot -->
          <circle class="hero-connector-dot hero-connector-dot--center" cx="400" cy="90" r="4.5"/>
        </svg>

        <!-- Final node -->
        <div class="hero-node hero-node--final" style="--node-delay: 1.3s">
          Launch your product
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       SECTION 2: THE PROBLEM
       ═══════════════════════════════════════════ -->
  <section id="problem" class="py-16 md:py-20 fade-in-section" aria-labelledby="problem-heading">
    <div class="max-w-[1280px] mx-auto px-5 md:px-10">
      <h2 id="problem-heading" class="type-h2 text-warm-black mb-10 md:mb-12 max-w-[672px]">You got 80% there.<br>The last 20% broke&nbsp;everything.</h2>

      <div class="grid sm:grid-cols-2 gap-4">
        <!-- Pain Card 1 -->
        <div class="problem-card">
          <div class="problem-card-img" aria-hidden="true">
            <img src="/images/2.png" alt="" class="h-full w-full object-cover">
          </div>
          <div class="problem-card-text">
            <h3 class="type-h4 mb-2">The demo works. Real users break&nbsp;it.</h3>
            <p class="type-body text-warm-mid">Login fails on edge cases. Payments succeed in test mode and fail in production. What you showed stakeholders isn't what your customers&nbsp;experience.</p>
          </div>
        </div>

        <!-- Pain Card 2 -->
        <div class="problem-card">
          <div class="problem-card-img" aria-hidden="true">
            <img src="/images/3.png" alt="" class="h-full w-full object-cover">
          </div>
          <div class="problem-card-text">
            <h3 class="type-h4 mb-2">Shared infrastructure. Zero&nbsp;security.</h3>
            <p class="type-body text-warm-mid">No dedicated database. No access control. No encryption. Your customer data is one misconfiguration away from&nbsp;exposure.</p>
          </div>
        </div>

        <!-- Pain Card 3 -->
        <div class="problem-card">
          <div class="problem-card-img" aria-hidden="true">
            <img src="/images/4.png" alt="" class="h-full w-full object-cover">
          </div>
          <div class="problem-card-text">
            <h3 class="type-h4 mb-2">Code you can't own, read, or hand&nbsp;off.</h3>
            <p class="type-body text-warm-mid">AI-generated spaghetti that no developer can pick up. When it breaks, you're stuck&nbsp;&mdash; and so is anyone you hire to&nbsp;help.</p>
          </div>
        </div>

        <!-- Pain Card 4 -->
        <div class="problem-card">
          <div class="problem-card-img" aria-hidden="true">
            <img src="/images/5.png" alt="" class="h-full w-full object-cover">
          </div>
          <div class="problem-card-text">
            <h3 class="type-h4 mb-2">Credits burned. Nobody to turn&nbsp;to.</h3>
            <p class="type-body text-warm-mid">Every fix creates a new bug. The AI loops on the same error. And there's no one on the other side to help you figure it&nbsp;out.</p>
          </div>
        </div>
      </div>

      <div class="problem-resolve mt-6">
        <p class="type-body-lg text-forest font-medium">There's a long way between built and launched. That's where we come&nbsp;in.</p>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       SECTION 3: VIDEO EMBED
       ═══════════════════════════════════════════ -->
  <section id="video" class="py-16 md:py-20 fade-in-section" aria-labelledby="video-heading">
    <div class="max-w-[1280px] mx-auto px-5 md:px-10">
      <h2 id="video-heading" class="type-h2 text-warm-black mb-10 text-center">This is what closing that gap looks&nbsp;like.</h2>
      <div class="video-embed-placeholder">
        <div class="video-embed-inner">
          <svg width="64" height="64" viewBox="0 0 64 64" fill="none" aria-hidden="true">
            <circle cx="32" cy="32" r="31" stroke="currentColor" stroke-width="2" opacity="0.2"/>
            <polygon points="26,20 48,32 26,44" fill="currentColor" opacity="0.2"/>
          </svg>
          <p class="type-body text-stone mt-4">Product walkthrough video<br><span class="type-body-sm">Max 45 seconds &middot; Auto-play</span></p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       SECTION 4: HOW AGENTQ WORKS
       ═══════════════════════════════════════════ -->
  <section id="how-it-works" class="py-16 md:py-20 fade-in-section" aria-labelledby="how-heading">
    <div class="max-w-[1280px] mx-auto px-5 md:px-10">
      <h2 id="how-heading" class="type-h2 text-warm-black mb-12 max-w-[768px]">From idea to launched&nbsp;product.</h2>

      <div class="grid lg:grid-cols-[1fr_1fr] gap-10 lg:gap-14">
        <!-- Left: Steps -->
        <div>
          <!-- AI LAYER LABEL -->
          <div class="mb-6 ai-layer-badge-wrap">
            <span class="ai-layer-badge">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.5"/><path d="M5 7h4M7 5v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              Agentic Engineering Layer
            </span>
          </div>

          <!-- Step 1 -->
          <div class="layer-ai pl-6 pb-8">
            <div class="flex items-baseline gap-3 mb-2">
              <span class="type-overline text-warm-black font-bold shrink-0">01</span>
              <h3 class="type-h4">Describe your product.</h3>
            </div>
            <p class="type-body text-warm-mid ml-8">Tell us what you need; a customer portal, a booking system, a marketplace, a SaaS app. Our PM agent works with you to turn your vision into a clear build&nbsp;plan.</p>
          </div>

          <!-- Step 2 -->
          <div class="layer-ai pl-6 pb-8">
            <div class="flex items-baseline gap-3 mb-2">
              <span class="type-overline text-warm-black font-bold shrink-0">02</span>
              <h3 class="type-h4">AI agents build it.</h3>
            </div>
            <p class="type-body text-warm-mid ml-8">A team of specialized AI agents gets to work. Backend developer designs your database and APIs. Frontend developer builds the UI. Code auditor reviews every&nbsp;line.</p>
          </div>

          <!-- Step 3 -->
          <div class="layer-ai pl-6 pb-8">
            <div class="flex items-baseline gap-3 mb-2">
              <span class="type-overline text-warm-black font-bold shrink-0">03</span>
              <h3 class="type-h4">Real developers step in.</h3>
            </div>
            <ul class="type-body text-warm-mid ml-8 space-y-2 pb-2">
              <li class="flex items-start gap-2"><span class="text-warm-black shrink-0 mt-1">&#10003;</span> Complex integrations? Real engineers handle it.</li>
              <li class="flex items-start gap-2"><span class="text-warm-black shrink-0 mt-1">&#10003;</span> Payment gateway? Wired by experts.</li>
              <li class="flex items-start gap-2"><span class="text-warm-black shrink-0 mt-1">&#10003;</span> Architecture reviews to solve for scalability? Done.</li>
              <li class="flex items-start gap-2"><span class="text-warm-black shrink-0 mt-1">&#10003;</span> No reviewing from a distance. Always working alongside you.</li>
            </ul>
          </div>

          <!-- Step 4 -->
          <div class="card mt-6" style="background: var(--color-forest); border: 1.5px solid var(--color-warm-black);">
            <div class="flex items-baseline gap-3 mb-2">
              <span class="type-overline text-white font-bold shrink-0">04</span>
              <h3 class="type-h4 text-white">You launch.</h3>
            </div>
            <ul class="type-body text-white/80 ml-8 space-y-2">
              <li class="flex items-start gap-2"><span class="shrink-0 mt-1">&#10003;</span> One-click deployment</li>
              <li class="flex items-start gap-2"><span class="shrink-0 mt-1">&#10003;</span> Dedicated database &amp; enterprise security</li>
              <li class="flex items-start gap-2"><span class="shrink-0 mt-1">&#10003;</span> Clean code you own completely</li>
              <li class="flex items-start gap-2"><span class="shrink-0 mt-1">&#10003;</span> Live in days, not months</li>
            </ul>
          </div>
        </div>

        <!-- Right: Image -->
        <div class="hidden lg:block">
          <div class="sticky top-24">
            <img src="/images/process.png" alt="AgentQ process" class="w-full h-auto rounded-card">
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       SECTION 5: DEVELOPER ASSIST
       ═══════════════════════════════════════════ -->
  <section id="developer-assist" class="py-16 md:py-20 fade-in-section" aria-labelledby="devassist-heading">
    <div class="max-w-[1280px] mx-auto px-5 md:px-10">
      <h2 id="devassist-heading" class="type-h2 text-warm-black mb-4 max-w-[576px]">Never stuck. Never&nbsp;alone.</h2>
      <p class="type-body-lg text-warm-mid mb-12 max-w-[768px]">All AgentQ plans include Developer Assist&nbsp;&mdash; a way to include real engineers in your workflow. No chatbots. No forums. Real engineers who understand your project and step in when it&nbsp;matters.</p>

      <!-- Capability Cards -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-12">
        <div class="card" style="background: var(--color-forest); border: 1.5px solid var(--color-warm-black);">
          <h4 class="type-h4 mb-2 text-white">Architecture &amp; planning</h4>
          <p class="type-body text-white/80">How should your app be structured so it scales? Database design, API layout, system architecture&nbsp;&mdash; the decisions that are invisible until they go&nbsp;wrong.</p>
        </div>
        <div class="card" style="background: var(--color-forest); border: 1.5px solid var(--color-warm-black);">
          <h4 class="type-h4 mb-2 text-white">Integrations</h4>
          <p class="type-body text-white/80">Stripe, Razorpay, HubSpot, Segment&nbsp;&mdash; if it has an API, we help you wire it up. Payment gateways, CRMs, analytics tools, any third-party&nbsp;service.</p>
        </div>
        <div class="card" style="background: var(--color-forest); border: 1.5px solid var(--color-warm-black);">
          <h4 class="type-h4 mb-2 text-white">Code review &amp; security</h4>
          <p class="type-body text-white/80">Professional review and optimisation before you go live. Security audit. Performance tuning. Best-practice&nbsp;enforcement.</p>
        </div>
        <div class="card" style="background: var(--color-forest); border: 1.5px solid var(--color-warm-black);">
          <h4 class="type-h4 mb-2 text-white">Deployment &amp; go-live</h4>
          <p class="type-body text-white/80">Deploy to production with confidence. A developer verifies everything works. No surprises on launch&nbsp;day.</p>
        </div>
      </div>

      <!-- Tier Cards -->
      <h3 class="section-label text-warm-mid mb-5">Support that scales with you.</h3>
      <div class="grid md:grid-cols-3 gap-4 mb-10">
        <div class="tier-card">
          <p class="type-overline text-stone mb-3">Standard</p>
          <h4 class="type-h4 mb-2">On-demand developer support.</h4>
          <p class="type-body text-warm-mid">Submit requests, get help with bugs, integrations, and architecture. For founders building their first&nbsp;product.</p>
        </div>
        <div class="tier-card-featured tier-card">
          <p class="type-overline text-forest mb-3">Priority</p>
          <h4 class="type-h4 mb-2">Faster response. Direct access.</h4>
          <p class="type-body" style="color: var(--color-stone);">Direct access to senior developers with faster turnaround. For founders handling real customers in&nbsp;production.</p>
        </div>
        <div class="tier-card">
          <p class="type-overline text-stone mb-3">Enterprise</p>
          <h4 class="type-h4 mb-2">Solutions architects, ground up.</h4>
          <p class="type-body text-warm-mid">Help with requirement gathering, scoping, and building complex multi-layered systems. For growing businesses with serious operational&nbsp;needs.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       SECTION 6: WHAT SHIPS BY DEFAULT
       ═══════════════════════════════════════════ -->
  <section id="what-ships" class="py-16 md:py-20 fade-in-section" aria-labelledby="ships-heading">
    <div class="max-w-[1280px] mx-auto px-5 md:px-10">
      <h2 id="ships-heading" class="type-h2 text-warm-black mb-10 max-w-[672px]">Production-ready isn't a feature.<br>It's the whole&nbsp;point.</h2>

      <div class="grid sm:grid-cols-2 gap-4">
        <!-- Item 1: Database -->
        <div class="ships-card">
          <div class="ships-card-text">
            <h3 class="type-h4 mb-2 text-forest">Dedicated PostgreSQL database</h3>
            <p class="type-body text-warm-mid">Your own database. Not shared infrastructure. Secure, relational, and built to scale with your&nbsp;business.</p>
          </div>
          <div class="ships-card-img" aria-hidden="true">
            <img src="/images/postgres.png" alt="" class="h-full w-full object-cover">
          </div>
        </div>

        <!-- Item 2: RBAC -->
        <div class="ships-card">
          <div class="ships-card-text">
            <h3 class="type-h4 mb-2 text-forest">Role-based access control</h3>
            <p class="type-body text-warm-mid">Built in from day one. Control who sees what across your entire application. Not bolted on after a data&nbsp;leak.</p>
          </div>
          <div class="ships-card-img" aria-hidden="true">
            <img src="/images/rbac.png" alt="" class="h-full w-full object-cover">
          </div>
        </div>

        <!-- Item 3: Security -->
        <div class="ships-card">
          <div class="ships-card-text">
            <h3 class="type-h4 mb-2 text-forest">Enterprise security</h3>
            <p class="type-body text-warm-mid">XSS protection. SQL injection prevention. DoS rate limiting. Input validation. Secure headers. Your customer data is protected from&nbsp;launch.</p>
          </div>
          <div class="ships-card-img" aria-hidden="true">
            <img src="/images/enterprise.png" alt="" class="h-full w-full object-cover">
          </div>
        </div>

        <!-- Item 4: TypeScript -->
        <div class="ships-card">
          <div class="ships-card-text">
            <h3 class="type-h4 mb-2 text-forest">Type-safe TypeScript</h3>
            <p class="type-body text-warm-mid">Clean, documented, maintainable code across frontend, backend, and database layer. Hand it to any developer. They'll understand&nbsp;it.</p>
          </div>
          <div class="ships-card-img" aria-hidden="true">
            <img src="/images/ts.png" alt="" class="h-full w-full object-cover">
          </div>
        </div>

        <!-- Item 5: Deploy -->
        <div class="ships-card">
          <div class="ships-card-text">
            <h3 class="type-h4 mb-2 text-forest">One-click deployment</h3>
            <p class="type-body text-warm-mid">Deno Deploy with Neon PostgreSQL and Cloudflare R2. Zero DevOps on your end. Live from the get&nbsp;go.</p>
          </div>
          <div class="ships-card-img" aria-hidden="true">
            <img src="/images/deploy.png" alt="" class="h-full w-full object-cover">
          </div>
        </div>

        <!-- Item 6: Ownership -->
        <div class="ships-card">
          <div class="ships-card-text">
            <h3 class="type-h4 mb-2 text-forest">Full code ownership</h3>
            <p class="type-body text-warm-mid">Your code is yours. Move it anywhere. Hand it to any team. No lock-in. No proprietary&nbsp;platforms.</p>
          </div>
          <div class="ships-card-img" aria-hidden="true">
            <img src="/images/own.png" alt="" class="h-full w-full object-cover">
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       SECTION 7: EVALS
       ═══════════════════════════════════════════ -->
  <section id="evals" class="py-16 md:py-20 fade-in-section" aria-labelledby="evals-heading">
    <div class="max-w-[1280px] mx-auto px-5 md:px-10">
      <h2 id="evals-heading" class="type-h2 text-warm-black mb-10 max-w-[672px]">Independently tested. Measurably&nbsp;better.</h2>

      <div class="grid lg:grid-cols-[2fr_1fr] gap-6">
        <!-- 2/3: Proof points -->
        <div class="space-y-4">
          <div class="card">
            <h3 class="type-h4 mb-2">97.7% of requirements captured on the first&nbsp;attempt.</h3>
            <p class="type-body text-warm-mid">When you describe your product, AgentQ doesn't skip things. The next closest platform captured 57%. Most missed nearly half of what was asked&nbsp;for.</p>
          </div>
          <div class="card">
            <h3 class="type-h4 mb-2">12 hours to production-ready.</h3>
            <p class="type-body text-warm-mid">Apps built with AgentQ needed 12 hours of developer work to reach full production readiness. The next closest platform needed 26. The worst needed&nbsp;60.</p>
          </div>
          <div class="card">
            <h3 class="type-h4 mb-2">15 questions asked before a single line of&nbsp;code.</h3>
            <p class="type-body text-warm-mid">AgentQ works like a good product manager; it figures out what you actually need before it builds. Some platforms asked zero questions and started building&nbsp;immediately.</p>
          </div>
          <div class="card">
            <h3 class="type-h4 mb-2">96% accuracy. What we said was built, was&nbsp;built.</h3>
            <p class="type-body text-warm-mid">Some platforms claim features are complete when they aren't. One showed 35% of features as built when they weren't actually working. AgentQ's accuracy was&nbsp;96%.</p>
          </div>
        </div>

        <!-- 1/3: Technical summary -->
        <div class="card" style="background: var(--color-warm-black); border-color: var(--color-warm-black); align-self: start;">
          <h3 class="type-h4 text-off-white mb-4">For the technical details</h3>
          <p class="type-body text-stone mb-6">AgentQ was evaluated across 68 metrics against 5 leading AI coding platforms using the QwikBuild-Bench framework. Highest score in engineering, backend infrastructure, security, and requirement&nbsp;capture.</p>
          <a href="/evals" class="type-body font-medium text-forest hover:text-forest-hover transition-colors">
            Read the full evaluation <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       SECTION 8: COMPARISON TABLE
       ═══════════════════════════════════════════ -->
  <section id="the-math" class="py-16 md:py-20 fade-in-section" aria-labelledby="math-heading">
    <div class="max-w-[1280px] mx-auto px-5 md:px-10">

      <h2 id="math-heading" class="type-h2 text-warm-black mb-10 md:mb-12">The cost of the&nbsp;alternatives.</h2>

      <!-- Desktop Table -->
      <div class="hidden md:block mb-16 overflow-x-auto">
        <table class="w-full border-separate border-spacing-0" role="table">
