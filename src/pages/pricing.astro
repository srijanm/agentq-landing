---
import BaseLayout from "../layouts/BaseLayout.astro";

const calendarUrl = "https://calendar.google.com/calendar/u/0/appointments/schedules/AcZssZ2VXsiZVbhgdnhV1tkQ9J6N-roCQlSd4CDDA5BHEcf36xdz-4OJSNM_56LSe5vDu9G6-AZRXkCj";
---

<BaseLayout title="Pricing — Starter, Business & Enterprise | AgentQ" description="Three plans from $20/mo. Agentic engineering, dedicated database, enterprise security, Developer Assist, full code ownership, one-click deployment.">

  <!-- ═══════════════════════════════════════════
       SECTION 1: THE PRICE
       ═══════════════════════════════════════════ -->
  <section class="pt-24 pb-16 md:pt-32 md:pb-20">
    <div class="max-w-[1280px] mx-auto px-5 md:px-10">
      <div class="text-center max-w-[672px] mx-auto mb-12">
        <h1 class="type-display text-warm-black mb-4">Simple pricing. Scale when you're&nbsp;ready.</h1>
        <p class="type-h3 text-warm-mid mb-10">Three plans. No surprise&nbsp;invoices.</p>

        <!-- Billing toggle -->
        <div class="flex justify-center">
          <div class="billing-toggle" role="tablist">
            <button class="billing-tab billing-tab--active" data-billing="monthly" role="tab" aria-selected="true">Monthly</button>
            <button class="billing-tab" data-billing="quarterly" role="tab" aria-selected="false">Quarterly (10% off)</button>
            <button class="billing-tab" data-billing="yearly" role="tab" aria-selected="false">Yearly (20% off)</button>
          </div>
        </div>
      </div>

      <!-- Pricing cards -->
      <div class="grid md:grid-cols-3 gap-4">
        <!-- Starter -->
        <div class="pricing-tier">
          <h3 class="type-h3 mb-1">Starter</h3>
          <p class="type-body text-warm-mid mb-4">For individuals getting started</p>
          <div class="mb-1">
            <span class="price-amount pricing-price" data-monthly="$20" data-quarterly="$18" data-yearly="$16">$20</span>
            <span class="price-period">/month</span>
          </div>
          <p class="type-body-sm text-stone mb-4 pricing-billed" data-monthly="$20 billed monthly" data-quarterly="$54 billed quarterly" data-yearly="$192 billed yearly">$20 billed monthly</p>
          <span class="pricing-credits mb-6">60 credits / month</span>
          <ul class="space-y-2.5 type-body mb-8 flex-1">
            <li class="flex items-start gap-3"><span class="text-forest shrink-0 mt-0.5">&#10003;</span><span>~10 Min Build Time</span></li>
            <li class="flex items-start gap-3"><span class="text-forest shrink-0 mt-0.5">&#10003;</span><span>Developer Assist Credits</span></li>
            <li class="flex items-start gap-3"><span class="text-forest shrink-0 mt-0.5">&#10003;</span><span>24 hours SLA on Dev Assist</span></li>
            <li class="flex items-start gap-3"><span class="text-forest shrink-0 mt-0.5">&#10003;</span><span>NoSQL Database</span></li>
            <li class="flex items-start gap-3"><span class="text-forest shrink-0 mt-0.5">&#10003;</span><span>Simple Admin/Non-Admin Roles</span></li>
            <li class="flex items-start gap-3"><span class="text-forest shrink-0 mt-0.5">&#10003;</span><span>Phone &amp; OTP Auth</span></li>
            <li class="flex items-start gap-3"><span class="text-forest shrink-0 mt-0.5">&#10003;</span><span>Rapid Blueprint Code</span></li>
            <li class="flex items-start gap-3"><span class="text-forest shrink-0 mt-0.5">&#10003;</span><span>One-Shot App Generation</span></li>
          </ul>
          <a href={calendarUrl} class="btn-primary w-full text-center">Subscribe</a>
        </div>

        <!-- Business (Most Popular) -->
        <div class="pricing-tier pricing-tier--featured">
          <span class="pricing-badge">Most Popular</span>
          <h3 class="type-h3 mb-1">Business</h3>
          <p class="type-body text-warm-mid mb-4">For professional developers and teams</p>
          <div class="mb-1">
            <span class="price-amount pricing-price" data-monthly="$200" data-quarterly="$180" data-yearly="$160">$200</span>
            <span class="price-period">/month</span>
          </div>
          <p class="type-body-sm text-stone mb-4 pricing-billed" data-monthly="$200 billed monthly" data-quarterly="$540 billed quarterly" data-yearly="$1,920 billed yearly">$200 billed monthly</p>
          <span class="pricing-credits mb-6">600 credits / month</span>
          <ul class="space-y-2.5 type-body mb-8 flex-1">
            <li class="flex items-start gap-3"><span class="text-forest shrink-0 mt-0.5">&#10003;</span><span>1-3 Hour Build Time</span></li>
            <li class="flex items-start gap-3"><span class="text-forest shrink-0 mt-0.5">&#10003;</span><span>Developer Assist Credits</span></li>
            <li class="flex items-start gap-3"><span class="text-forest shrink-0 mt-0.5">&#10003;</span><span>3 hours SLA on Dev Assist</span></li>
            <li class="flex items-start gap-3"><span class="text-forest shrink-0 mt-0.5">&#10003;</span><span>Dedicated PostgreSQL with Full Access</span></li>
            <li class="flex items-start gap-3"><span class="text-forest shrink-0 mt-0.5">&#10003;</span><span>Unlimited Custom Roles &amp; RBAC</span></li>
            <li class="flex items-start gap-3"><span class="text-forest shrink-0 mt-0.5">&#10003;</span><span>Multiple Auth Methods (OAuth, Email, Phone)</span></li>
            <li class="flex items-start gap-3"><span class="text-forest shrink-0 mt-0.5">&#10003;</span><span>Type-Safe Code + AI Code Audit</span></li>
            <li class="flex items-start gap-3"><span class="text-forest shrink-0 mt-0.5">&#10003;</span><span>Execution Traces &amp; Full Code History</span></li>
            <li class="flex items-start gap-3"><span class="text-forest shrink-0 mt-0.5">&#10003;</span><span>Scalable Serverless Architecture</span></li>
            <li class="flex items-start gap-3"><span class="text-forest shrink-0 mt-0.5">&#10003;</span><span>XSS, SQL Injection &amp; DoS Protection</span></li>
            <li class="flex items-start gap-3"><span class="text-forest shrink-0 mt-0.5">&#10003;</span><span>Direct Code Editability</span></li>
          </ul>
          <a href={calendarUrl} class="btn-primary w-full text-center">Subscribe</a>
        </div>

        <!-- Enterprise -->
        <div class="pricing-tier">
          <h3 class="type-h3 mb-1">Enterprise</h3>
          <p class="type-body text-warm-mid mb-4">Custom terms for large scale</p>
          <div class="mb-1">
            <span class="price-amount pricing-price" data-monthly="$2,000" data-quarterly="$1,800" data-yearly="$1,600">$2,000</span>
            <span class="price-period">/month</span>
          </div>
          <p class="type-body-sm text-stone mb-4 pricing-billed" data-monthly="$2,000 billed monthly" data-quarterly="$5,400 billed quarterly" data-yearly="$19,200 billed yearly">$2,000 billed monthly</p>
          <span class="pricing-credits mb-6">6000 credits / month</span>
          <ul class="space-y-2.5 type-body mb-8 flex-1">
            <li class="flex items-start gap-3"><span class="text-forest shrink-0 mt-0.5">&#10003;</span><span>1-3 Hour Build Time</span></li>
            <li class="flex items-start gap-3"><span class="text-forest shrink-0 mt-0.5">&#10003;</span><span>Developer Assist Credits</span></li>
            <li class="flex items-start gap-3"><span class="text-forest shrink-0 mt-0.5">&#10003;</span><span>30 min SLA on Dev Assist</span></li>
            <li class="flex items-start gap-3"><span class="text-forest shrink-0 mt-0.5">&#10003;</span><span>Org Team Collaboration &amp; Sharing</span></li>
            <li class="flex items-start gap-3"><span class="text-forest shrink-0 mt-0.5">&#10003;</span><span>Hands-On Education &amp; Training on AI Agentic Engineering</span></li>
            <li class="flex items-start gap-3"><span class="text-forest shrink-0 mt-0.5">&#10003;</span><span>Dedicated PostgreSQL with Full Access</span></li>
            <li class="flex items-start gap-3"><span class="text-forest shrink-0 mt-0.5">&#10003;</span><span>Unlimited Custom Roles &amp; RBAC</span></li>
            <li class="flex items-start gap-3"><span class="text-forest shrink-0 mt-0.5">&#10003;</span><span>Multiple Auth Methods (OAuth, Email, Phone)</span></li>
            <li class="flex items-start gap-3"><span class="text-forest shrink-0 mt-0.5">&#10003;</span><span>Type-Safe Code + AI Code Audit</span></li>
            <li class="flex items-start gap-3"><span class="text-forest shrink-0 mt-0.5">&#10003;</span><span>Execution Traces &amp; Full Code History</span></li>
            <li class="flex items-start gap-3"><span class="text-forest shrink-0 mt-0.5">&#10003;</span><span>Scalable Serverless Architecture</span></li>
            <li class="flex items-start gap-3"><span class="text-forest shrink-0 mt-0.5">&#10003;</span><span>XSS, SQL Injection &amp; DoS Protection</span></li>
            <li class="flex items-start gap-3"><span class="text-forest shrink-0 mt-0.5">&#10003;</span><span>Direct Code Editability</span></li>
            <li class="flex items-start gap-3"><span class="text-forest shrink-0 mt-0.5">&#10003;</span><span>Organisation &amp; Team Management</span></li>
            <li class="flex items-start gap-3"><span class="text-forest shrink-0 mt-0.5">&#10003;</span><span>Custom Development</span></li>
            <li class="flex items-start gap-3"><span class="text-forest shrink-0 mt-0.5">&#10003;</span><span>Private Cloud Deployment</span></li>
          </ul>
          <a href={calendarUrl} class="btn-primary w-full text-center">Contact Us</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       SECTION 2: PUT IT IN CONTEXT
       ═══════════════════════════════════════════ -->
  <section class="py-16 md:py-20 fade-in-section" aria-labelledby="context-heading">
    <div class="max-w-[1280px] mx-auto px-5 md:px-10">
      <h2 id="context-heading" class="type-h2 text-warm-black mb-10">Put it in&nbsp;context.</h2>

      <div class="grid md:grid-cols-3 gap-4">
        <div class="card">
          <h3 class="type-h4 mb-2">vs. AI coding tools</h3>
          <p class="type-body text-warm-mid">Lovable, Bolt, Replit, and similar tools run $20–$100/month. A year at mid-tier adds up to $600–$1,200. Most users in that range spend months burning credits and never reach a launchable&nbsp;product.</p>
        </div>
        <div class="card">
          <h3 class="type-h4 mb-2">vs. a freelancer</h3>
          <p class="type-body text-warm-mid">A freelancer who can build production-grade software starts at $5,000 for an MVP. Takes weeks. You manage them, review their work, and hope they're still available when something breaks next&nbsp;month.</p>
        </div>
        <div class="card">
          <h3 class="type-h4 mb-2">vs. an agency</h3>
          <p class="type-body text-warm-mid">Agencies charge $10,000–$50,000 per project and take 3–6 months. You manage the vendor, the timeline, and the scope. Costs creep upward. Delays are&nbsp;standard.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       SECTION 3: PRICING FAQ
       ═══════════════════════════════════════════ -->
  <section class="py-16 md:py-20 fade-in-section" aria-labelledby="pricing-faq-heading">
    <div class="max-w-[1280px] mx-auto px-5 md:px-10">
      <div style="border: 1.5px solid var(--color-warm-black); border-radius: var(--radius-card); padding: 40px;">
        <h2 id="pricing-faq-heading" class="type-h2 text-warm-black mb-10">Common questions about&nbsp;pricing</h2>

        <div class="divide-y divide-warm-black/10">
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">
              <span>"It costs more than Lovable."</span>
              <svg class="faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </button>
            <div class="faq-answer">
              <p class="type-body text-warm-mid pb-2">A year on Lovable at mid-tier runs $600–$1,200. Most users in that range spend months and never launch. AgentQ costs $600 a quarter and includes production-ready software, developer support, and deployment. The better question: which one gets you to&nbsp;launch?</p>
            </div>
          </div>
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">
              <span>"Why not just use ChatGPT or Cursor?"</span>
              <svg class="faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </button>
            <div class="faq-answer">
              <p class="type-body text-warm-mid pb-2">These are powerful tools for developers. They require you to understand code, debug errors, make architecture decisions, and handle deployment. If you're technical, they're great. AgentQ is for people who want to describe what they need and get working software&nbsp;back.</p>
            </div>
          </div>
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">
              <span>"Why not hire a freelancer?"</span>
              <svg class="faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </button>
            <div class="faq-answer">
              <p class="type-body text-warm-mid pb-2">A freelancer starts at $5,000 for an MVP and takes weeks. You manage them, review their work, and hope they stick around for fixes. AgentQ costs $200 a month, delivers in days, and the developer support is ongoing. When you need changes next month, the support is still&nbsp;there.</p>
            </div>
          </div>
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">
              <span>"What happens after the quarter ends?"</span>
              <svg class="faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </button>
            <div class="faq-answer">
              <p class="type-body text-warm-mid pb-2">Renew and keep building. Your app stays live, your database keeps running, Developer Assist stays available. Choose not to renew and you still keep your code. It's yours. Host it&nbsp;anywhere.</p>
            </div>
          </div>
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">
              <span>"Are there any additional costs?"</span>
              <svg class="faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </button>
            <div class="faq-answer">
              <p class="type-body text-warm-mid pb-2">No hidden fees. The $600 covers AI coding, hosting, and Developer Assist. If your project requires paid third-party services, we'll tell you before any work&nbsp;starts.</p>
            </div>
          </div>
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">
              <span>"Can I start with a smaller project to test it?"</span>
              <svg class="faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </button>
            <div class="faq-answer">
              <p class="type-body text-warm-mid pb-2">Yes. Most customers start with a single tool or MVP and expand from there. $600 gets you a launched product, not a commitment to rebuild your entire business on day&nbsp;one.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       SECTION 4: CTA
       ═══════════════════════════════════════════ -->
  <section class="py-16 md:py-20 fade-in-section">
    <div class="max-w-[1280px] mx-auto px-5 md:px-10 text-center">
      <h2 class="type-h2 text-warm-black mb-4">Plans from $20/mo. A launched product. Code you&nbsp;own.</h2>
      <a href={calendarUrl} class="btn-primary text-lg mt-6">
        Book a launch call <span aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </section>

</BaseLayout>
