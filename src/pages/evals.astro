            <tr><td class="py-3 pr-6 border-b border-warm-black/5 text-warm-mid">Platform B</td><td class="py-3 px-6 border-b border-warm-black/5 text-warm-mid">47.8%</td><td class="py-3 px-6 border-b border-warm-black/5 text-warm-mid">FinTech-AI (54.5%)</td><td class="py-3 px-6 border-b border-warm-black/5 text-warm-mid">Background Jobs (0%)</td></tr>
            <tr><td class="py-3 pr-6 border-b border-warm-black/5 text-warm-mid">Platform C</td><td class="py-3 px-6 border-b border-warm-black/5 text-warm-mid">46.9%</td><td class="py-3 px-6 border-b border-warm-black/5 text-warm-mid">Field Service (53.8%)</td><td class="py-3 px-6 border-b border-warm-black/5 text-warm-mid">SEO/Web Standards (13%)</td></tr>
