---
import BaseLayout from "../layouts/BaseLayout.astro";

const calendarUrl = "https://calendar.google.com/calendar/u/0/appointments/schedules/AcZssZ2VXsiZVbhgdnhV1tkQ9J6N-roCQlSd4CDDA5BHEcf36xdz-4OJSNM_56LSe5vDu9G6-AZRXkCj";
---

<BaseLayout>

  <!-- ═══════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════ -->
  <section aria-label="Hero" class="hero-centered">
    <div class="hero-bg" aria-hidden="true">
      <img src="/images/hero-bg.png" alt="" class="hero-bg-img">
    </div>
    <div class="min-h-[100svh] flex flex-col items-center justify-start pt-24 md:pt-40 pb-8 relative z-10">
      <div class="max-w-[960px] mx-auto px-5 md:px-10 w-full text-center">

        <!-- Badge pill -->
        <span class="hero-video-pill mb-8 md:mb-12 inline-flex" style="cursor: default;">
          <span class="exp2-green-dot" aria-hidden="true"></span>
          Independently tested against 5 platforms
        </span>

        <h1 class="type-display text-warm-black mb-5 md:mb-8">Bespoke business software launched in <span class="text-forest">days,</span> not&nbsp;months.</h1>
        <p class="type-h3 text-warm-mid mb-10 md:mb-14 max-w-[672px] mx-auto">AI agents build your software. Real developers make sure it works in&nbsp;production.</p>

        <a href={calendarUrl} class="btn-primary">
          Book a demo <span aria-hidden="true">&rarr;</span>
        </a>
      </div>

      <!-- Animated 3→1 process diagram -->
      <div class="hero-process-diagram">
        <div class="hero-process-nodes">
          <div class="hero-node hero-node--step" style="--node-delay: 0.3s">
            Describe your product
          </div>
          <div class="hero-node hero-node--step" style="--node-delay: 0.6s">
            AI agents build it
          </div>
          <div class="hero-node hero-node--step" style="--node-delay: 0.9s">
            Real developers step in
          </div>
        </div>

        <!-- Connector lines (SVG) — tree structure with junction dots -->
        <svg class="hero-connectors" viewBox="0 0 800 120" fill="none" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
          <!-- Lines from step nodes down to junction points -->
          <line class="hero-connector-line" x1="133" y1="0" x2="133" y2="40"/>
          <line class="hero-connector-line" x1="400" y1="0" x2="400" y2="40"/>
          <line class="hero-connector-line" x1="667" y1="0" x2="667" y2="40"/>

          <!-- Lines from junctions converging to center -->
          <line class="hero-connector-line" x1="133" y1="40" x2="400" y2="90"/>
          <line class="hero-connector-line" x1="400" y1="40" x2="400" y2="90"/>
          <line class="hero-connector-line" x1="667" y1="40" x2="400" y2="90"/>

          <!-- Junction dots -->
          <circle class="hero-connector-dot" cx="133" cy="40" r="3.5"/>
          <circle class="hero-connector-dot" cx="400" cy="40" r="3.5"/>
          <circle class="hero-connector-dot" cx="667" cy="40" r="3.5"/>

          <!-- Center convergence dot -->
          <circle class="hero-connector-dot hero-connector-dot--center" cx="400" cy="90" r="4.5"/>
        </svg>

        <!-- Final node -->
        <div class="hero-node hero-node--final" style="--node-delay: 1.3s">
          LAUNCH
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       TRUST BAR
       ═══════════════════════════════════════════ -->
  <section class="py-10 md:py-14 fade-in-section" aria-label="Key stats">
    <div class="max-w-[1280px] mx-auto px-5 md:px-10">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-4 text-center">
        <div class="stat-card">
          <p class="type-h2 text-forest font-bold mb-1">10,000+</p>
          <p class="type-body text-stone">Apps built on QwikBuild</p>
        </div>
        <div class="stat-card">
          <p class="type-h2 text-forest font-bold mb-1">99%</p>
          <p class="type-body text-stone">Platform uptime</p>
        </div>
        <div class="stat-card">
          <p class="type-h2 text-forest font-bold mb-1">Days</p>
          <p class="type-body text-stone">Idea to launch</p>
        </div>
        <div class="stat-card">
          <p class="type-h2 text-forest font-bold mb-1">1st</p>
          <p class="type-body text-stone">Out of 5 tested AI coding platforms</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       SECTION 2: THE PROBLEM
       ═══════════════════════════════════════════ -->
  <section id="problem" class="py-16 md:py-20 fade-in-section" aria-labelledby="problem-heading">
    <div class="max-w-[1280px] mx-auto px-5 md:px-10">
      <h2 id="problem-heading" class="type-h2 text-warm-black mb-4 md:mb-5 max-w-[768px] mx-auto text-center">Vibecoding gets you 80% there. We bridge the&nbsp;gap.</h2>
      <p class="type-body-lg text-warm-mid mb-10 md:mb-12 max-w-[768px] mx-auto text-center">Helping non-technical founders &amp; small business owners finish what they&nbsp;started.</p>

      <div class="grid sm:grid-cols-2 gap-4">
        <div class="problem-card">
          <div class="problem-card-img" aria-hidden="true">
            <img src="/images/2.png" alt="" class="h-full w-full object-cover">
          </div>
          <div class="problem-card-text">
            <h3 class="type-h4 mb-2">The demo works. Real users break&nbsp;it.</h3>
            <ul class="type-body text-warm-mid space-y-1 list-disc pl-5">
              <li>Login/Auth doesn't work</li>
              <li>Payments fail on production</li>
            </ul>
          </div>
        </div>
        <div class="problem-card">
          <div class="problem-card-img" aria-hidden="true">
            <img src="/images/3.png" alt="" class="h-full w-full object-cover">
          </div>
          <div class="problem-card-text">
            <h3 class="type-h4 mb-2">Shared infrastructure. Zero&nbsp;security.</h3>
            <ul class="type-body text-warm-mid space-y-1 list-disc pl-5">
              <li>Broken databases &amp; access control</li>
              <li>No encryption &amp; vulnerabilities</li>
            </ul>
          </div>
        </div>
        <div class="problem-card">
          <div class="problem-card-img" aria-hidden="true">
            <img src="/images/4.png" alt="" class="h-full w-full object-cover">
          </div>
          <div class="problem-card-text">
            <h3 class="type-h4 mb-2">Code you can't own, read, or hand&nbsp;off.</h3>
            <ul class="type-body text-warm-mid space-y-1 list-disc pl-5">
              <li>Illegible AI-generated spaghetti code</li>
              <li>Hard to export off platform</li>
            </ul>
          </div>
        </div>
        <div class="problem-card">
          <div class="problem-card-img" aria-hidden="true">
            <img src="/images/5.png" alt="" class="h-full w-full object-cover">
          </div>
          <div class="problem-card-text">
            <h3 class="type-h4 mb-2">Credits burned. Nobody to turn&nbsp;to.</h3>
            <ul class="type-body text-warm-mid space-y-1 list-disc pl-5">
              <li>&ldquo;Fixes&rdquo; create new bugs</li>
              <li>AI loops on the same error</li>
            </ul>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       SECTION 3: VIDEO EMBED
       ═══════════════════════════════════════════ -->
  <section id="video" class="py-16 md:py-20 fade-in-section" aria-labelledby="video-heading">
    <div class="max-w-[1280px] mx-auto px-5 md:px-10">
      <h2 id="video-heading" class="type-h2 text-warm-black mb-10 text-center">Taking you from built to launched, one step at a&nbsp;time.</h2>
      <div style="border-radius: var(--radius-container); overflow: hidden; border: 1.5px solid var(--color-warm-black);">
        <video autoplay muted loop playsinline style="width: 100%; display: block;">
          <source src="/images/AgentQ_FHD_1.mp4" type="video/mp4">
        </video>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       HOW IT WORKS
       ═══════════════════════════════════════════ -->
  <section id="how" class="py-16 md:py-20 fade-in-section" aria-labelledby="how-heading">
    <div class="max-w-[1280px] mx-auto px-5 md:px-10">
      <p class="type-overline text-stone mb-4">How it works</p>
      <h2 id="how-heading" class="type-h2 text-warm-black mb-12 max-w-[768px]">From idea to launched&nbsp;product.</h2>

      <div class="grid lg:grid-cols-[1fr_1fr] gap-10 lg:gap-14">
        <div>
          <!-- Step 1 -->
          <div class="layer-ai pl-6 pb-8">
            <div class="flex items-baseline gap-3 mb-2">
              <span class="type-overline text-warm-black font-bold shrink-0">01</span>
              <h3 class="type-h4">Describe your product.</h3>
            </div>
            <p class="type-body text-warm-mid ml-8">Tell us what you need &mdash; a customer portal, a booking system, a SaaS app. Our PM agent asks the right questions to turn your vision into a build&nbsp;plan.</p>
          </div>

          <!-- Step 2 -->
          <div class="layer-ai pl-6 pb-8">
            <div class="flex items-baseline gap-3 mb-2">
              <span class="type-overline text-warm-black font-bold shrink-0">02</span>
              <h3 class="type-h4">AI agents build it.</h3>
            </div>
            <p class="type-body text-warm-mid ml-8">Backend dev designs your database and APIs. Frontend dev builds the UI. Code auditor reviews every line. All in&nbsp;days.</p>
          </div>

          <!-- Step 3 — highlighted as differentiator -->
          <div class="pl-6 pb-8 exp2-step-highlight">
            <div class="flex items-baseline gap-3 mb-2">
              <span class="type-overline text-forest font-bold shrink-0">03</span>
              <h3 class="type-h4">Real developers step&nbsp;in.</h3>
            </div>
            <p class="type-body text-warm-mid ml-8">Complex integrations, payment gateways, architecture reviews. Real engineers in your workflow &mdash; not a chatbot, not a&nbsp;forum.</p>
          </div>

          <!-- Step 4 -->
          <div class="card mt-6" style="background: var(--color-forest); border: 1.5px solid var(--color-warm-black);">
            <div class="flex items-baseline gap-3 mb-2">
              <span class="type-overline text-white font-bold shrink-0">04</span>
              <h3 class="type-h4 text-white">You launch.</h3>
            </div>
            <p class="type-body text-white/80 ml-8">One-click deployment. Dedicated database. Enterprise security. Clean code you own completely. Live in&nbsp;days.</p>
          </div>
        </div>

        <!-- Right: Image -->
        <div class="hidden lg:block">
          <div class="sticky top-24">
            <img src="/images/process.png" alt="AgentQ process" class="w-full h-auto rounded-card">
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       SECTION 5: DEVELOPER ASSIST
       ═══════════════════════════════════════════ -->
  <section id="developer-assist" class="py-16 md:py-20 fade-in-section" aria-labelledby="devassist-heading">
    <div class="max-w-[1280px] mx-auto px-5 md:px-10">
      <h2 id="devassist-heading" class="type-h2 text-warm-black mb-4 max-w-[576px]">Never stuck. Never&nbsp;alone.</h2>
      <p class="type-body-lg text-warm-mid mb-12 max-w-[768px]">Real engineers in your workflow to help with the tricky&nbsp;bits.</p>

      <!-- Capability Cards -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-12">
        <div class="card" style="background: var(--color-forest); border: 1.5px solid var(--color-warm-black);">
          <h4 class="type-h4 mb-2 text-white">Architecture &amp; planning</h4>
          <p class="type-body text-white/80">Build an app that doesn't break when it scales with intelligent database design, API layouts &amp; system&nbsp;architecture.</p>
        </div>
        <div class="card" style="background: var(--color-forest); border: 1.5px solid var(--color-warm-black);">
          <h4 class="type-h4 mb-2 text-white">Integrations</h4>
          <p class="type-body text-white/80">Wire up APIs like payment gateways, CRMs, analytics tools &amp; any third-party services&nbsp;seamlessly.</p>
        </div>
        <div class="card" style="background: var(--color-forest); border: 1.5px solid var(--color-warm-black);">
          <h4 class="type-h4 mb-2 text-white">Code review &amp; security</h4>
          <p class="type-body text-white/80">Professionally review your security, performance &amp; best practices before you go&nbsp;live.</p>
        </div>
        <div class="card" style="background: var(--color-forest); border: 1.5px solid var(--color-warm-black);">
          <h4 class="type-h4 mb-2 text-white">Deployment &amp; go-live</h4>
          <p class="type-body text-white/80">Launch with no surprises after verifying that everything works with a developer who knows your&nbsp;code.</p>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       SECTION 6: WHAT SHIPS BY DEFAULT
       ═══════════════════════════════════════════ -->
  <section id="what-ships" class="py-16 md:py-20 fade-in-section" aria-labelledby="ships-heading">
    <div class="max-w-[1280px] mx-auto px-5 md:px-10">
      <h2 id="ships-heading" class="type-h2 text-warm-black mb-10 max-w-[672px]">Production ready from the&nbsp;get-go.</h2>

      <div class="grid sm:grid-cols-2 gap-4">
        <!-- Item 1: Database -->
        <div class="ships-card">
          <div class="ships-card-text">
            <h3 class="type-h4 mb-2 text-forest">Your own secure database</h3>
            <p class="type-body text-warm-mid">Dedicated PostgreSQL database built to scale with your&nbsp;business.</p>
          </div>
          <div class="ships-card-img" aria-hidden="true">
            <img src="/images/postgres.png" alt="" class="h-full w-full object-cover">
          </div>
        </div>

        <!-- Item 2: RBAC -->
        <div class="ships-card">
          <div class="ships-card-text">
            <h3 class="type-h4 mb-2 text-forest">Control who sees what</h3>
            <p class="type-body text-warm-mid">Role-based access control built for privacy &amp;&nbsp;security.</p>
          </div>
          <div class="ships-card-img" aria-hidden="true">
            <img src="/images/rbac.png" alt="" class="h-full w-full object-cover">
          </div>
        </div>

        <!-- Item 3: Security -->
        <div class="ships-card">
          <div class="ships-card-text">
            <h3 class="type-h4 mb-2 text-forest">Enterprise grade security</h3>
            <p class="type-body text-warm-mid">XSS protection, SQL injection prevention &amp; DoS rate&nbsp;limiting.</p>
          </div>
          <div class="ships-card-img" aria-hidden="true">
            <img src="/images/enterprise.png" alt="" class="h-full w-full object-cover">
          </div>
        </div>

        <!-- Item 4: TypeScript -->
        <div class="ships-card">
          <div class="ships-card-text">
            <h3 class="type-h4 mb-2 text-forest">Clean, legible code</h3>
            <p class="type-body text-warm-mid"><strong>Type-safe TypeScript</strong> you can hand to your&nbsp;developer.</p>
          </div>
          <div class="ships-card-img" aria-hidden="true">
            <img src="/images/ts.png" alt="" class="h-full w-full object-cover">
          </div>
        </div>

        <!-- Item 5: Deploy -->
        <div class="ships-card">
          <div class="ships-card-text">
            <h3 class="type-h4 mb-2 text-forest">One-click deployment</h3>
            <p class="type-body text-warm-mid">Zero DevOps on your end to launch as fast as&nbsp;possible.</p>
          </div>
          <div class="ships-card-img" aria-hidden="true">
            <img src="/images/deploy.png" alt="" class="h-full w-full object-cover">
          </div>
        </div>

        <!-- Item 6: Ownership -->
        <div class="ships-card">
          <div class="ships-card-text">
            <h3 class="type-h4 mb-2 text-forest">Full code ownership</h3>
            <p class="type-body text-warm-mid">Your code belongs to you. Move it&nbsp;anywhere.</p>
          </div>
          <div class="ships-card-img" aria-hidden="true">
            <img src="/images/own.png" alt="" class="h-full w-full object-cover">
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       SECTION 7: EVALS
       ═══════════════════════════════════════════ -->
  <section id="evals" class="py-16 md:py-20 fade-in-section" aria-labelledby="evals-heading">
    <div class="max-w-[1280px] mx-auto px-5 md:px-10">
      <h2 id="evals-heading" class="type-h2 text-warm-black mb-10 max-w-[672px]">Independently tested. Measurably&nbsp;better.</h2>

      <!-- Eval chart -->
      <div class="mb-10" style="border: 1.5px solid var(--color-warm-black); border-radius: var(--radius-card); overflow: hidden;">
        <img src="/images/evals-chart.png" alt="Engineering scores: QwikBuild vs Emergent, Lovable, v0-Max, Replit across EdTech, Field Service, and FinTech-AI domains" class="w-full h-auto">
      </div>

      <div class="grid lg:grid-cols-[2fr_1fr] gap-6">
        <!-- 2/3: Proof points -->
        <div class="space-y-4">
          <div class="card">
            <h3 class="type-h4 mb-2">97.7% of requirements captured on the first&nbsp;attempt.</h3>
            <p class="type-body text-warm-mid">The next closest platform captured&nbsp;57%.</p>
          </div>
          <div class="card">
            <h3 class="type-h4 mb-2">12 hours to production-ready.</h3>
            <p class="type-body text-warm-mid">The next closest platform needed 26 &amp; the worst needed&nbsp;60.</p>
          </div>
          <div class="card">
            <h3 class="type-h4 mb-2">15 questions asked before a single line of&nbsp;code.</h3>
            <p class="type-body text-warm-mid">AgentQ figures out what you actually need before it&nbsp;builds.</p>
          </div>
          <div class="card">
            <h3 class="type-h4 mb-2">96% accuracy. What we say was built, gets&nbsp;built.</h3>
            <p class="type-body text-warm-mid">A competitor showed 35% of features as built when they weren't actually&nbsp;working.</p>
          </div>
        </div>

        <!-- 1/3: Technical summary + CTA stacked -->
        <div class="space-y-4" style="align-self: start;">
          <div class="card" style="background: var(--color-warm-black); border-color: var(--color-warm-black);">
            <h3 class="type-h4 text-off-white mb-4">For the technical details</h3>
            <p class="type-body text-stone mb-6">AgentQ was evaluated across 68 metrics against 5 leading AI coding platforms using the QwikBuild-Bench&nbsp;framework.</p>
            <a href="/evals" class="type-body font-medium text-forest hover:text-forest-hover transition-colors">
              Read the full evaluation <span aria-hidden="true">&rarr;</span>
            </a>
          </div>

          <div class="card" style="background: var(--color-forest); border: 1.5px solid var(--color-warm-black);">
            <h3 class="type-h4 text-white mb-2">See the data in action.</h3>
            <p class="type-body text-white/70 mb-4">Book a demo and we'll walk you through what AgentQ can build for&nbsp;you.</p>
            <form class="email-cta-row" style="max-width: 100%;" novalidate>
              <input type="email" class="email-cta-input" placeholder="Your email" required>
              <a href={calendarUrl} class="btn-primary email-cta-btn" style="background-color: var(--color-warm-black);" data-calendar-url={calendarUrl}>
                Book a Demo <span aria-hidden="true">&rarr;</span>
              </a>
            </form>
          </div>
        </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       SECTION 8: COMPARISON TABLE
       ═══════════════════════════════════════════ -->
  <section id="the-math" class="py-16 md:py-20 fade-in-section" aria-labelledby="math-heading">
    <div class="max-w-[1280px] mx-auto px-5 md:px-10">

      <h2 id="math-heading" class="type-h2 text-warm-black mb-10 md:mb-12">The cost of the&nbsp;alternatives.</h2>

      <!-- Desktop Table -->
      <div class="hidden md:block mb-16 overflow-x-auto">
        <table class="w-full border-separate border-spacing-0" role="table">
          <thead>
            <tr>
              <th class="text-left type-body font-semibold pb-4 pr-6 border-b-2 border-warm-black/10" style="width: 16%"></th>
              <th class="text-left type-body font-semibold pb-4 px-6 border-b-2 border-warm-black/10">AI Builders</th>
              <th class="text-left type-body font-semibold pb-4 px-8 border-b-2 border-forest comparison-col-highlight rounded-t-card">
                AgentQ
              </th>
              <th class="text-left type-body font-semibold pb-4 px-6 border-b-2 border-warm-black/10">Agencies</th>
              <th class="text-left type-body font-semibold pb-4 px-6 border-b-2 border-warm-black/10">Hiring</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="py-4 pr-6 type-body font-semibold border-b border-warm-black/5">Cost</td>
              <td class="py-4 px-6 type-body border-b border-warm-black/5 text-warm-mid">$20&ndash;$100/mo</td>
              <td class="py-4 px-8 type-body border-b border-forest/10 comparison-col-highlight font-medium">$200/mo</td>
              <td class="py-4 px-6 type-body border-b border-warm-black/5 text-warm-mid">$5K&ndash;$50K per project</td>
              <td class="py-4 px-6 type-body border-b border-warm-black/5 text-warm-mid">$80K+/year</td>
            </tr>
            <tr>
              <td class="py-4 pr-6 type-body font-semibold border-b border-warm-black/5">Skill required</td>
              <td class="py-4 px-6 type-body border-b border-warm-black/5 text-warm-mid">None</td>
              <td class="py-4 px-8 type-body border-b border-forest/10 comparison-col-highlight font-medium">None</td>
              <td class="py-4 px-6 type-body border-b border-warm-black/5 text-warm-mid">Must manage the project</td>
              <td class="py-4 px-6 type-body border-b border-warm-black/5 text-warm-mid">Must recruit and manage</td>
            </tr>
            <tr>
              <td class="py-4 pr-6 type-body font-semibold border-b border-warm-black/5">Output</td>
              <td class="py-4 px-6 type-body border-b border-warm-black/5 text-warm-mid">Demo-ready</td>
              <td class="py-4 px-8 type-body border-b border-forest/10 comparison-col-highlight font-medium">Production-ready</td>
              <td class="py-4 px-6 type-body border-b border-warm-black/5 text-warm-mid">Production-ready</td>
              <td class="py-4 px-6 type-body border-b border-warm-black/5 text-warm-mid">Production-ready</td>
            </tr>
            <tr>
              <td class="py-4 pr-6 type-body font-semibold border-b border-warm-black/5">Dev support</td>
              <td class="py-4 px-6 type-body border-b border-warm-black/5 text-warm-mid">None</td>
              <td class="py-4 px-8 type-body border-b border-forest/10 comparison-col-highlight font-medium">Built into every plan</td>
              <td class="py-4 px-6 type-body border-b border-warm-black/5 text-warm-mid">Full team (at full price)</td>
              <td class="py-4 px-6 type-body border-b border-warm-black/5 text-warm-mid">You are the manager</td>
            </tr>
            <tr>
